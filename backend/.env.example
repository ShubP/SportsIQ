# --- Database ---------------------------------------------------------------
# Leave unset for local dev (uses a local SQLite file: backend/courtiq.db).
# For prod, use your Neon Postgres URL (note the +psycopg2 driver + sslmode):
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# --- The Odds API (https://the-odds-api.com) --------------------------------
# Free tier gives 500 requests/month. Without this, the pipeline generates
# clearly-labeled DEMO lines so the app still runs.
THE_ODDS_API_KEY=
ODDS_API_REGION=us
# Optional CSV of bookmakers to restrict to (e.g. draftkings,fanduel).
ODDS_API_BOOKMAKERS=

# --- Pipeline tuning --------------------------------------------------------
SEASON=2026
LOOKAHEAD_DAYS=2
HISTORY_LOOKBACK_DAYS=365

# --- API CORS ---------------------------------------------------------------
# Your deployed frontend origin (Vercel). Localhost:5173 is allowed by default.
FRONTEND_ORIGIN=
